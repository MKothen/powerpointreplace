{
  "name": "lectern",
  "version": "0.1.0",
  "private": true,
  "description": "A presentation tool for academic talks: visual editor, file-based decks, Claude Code as the AI engine.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lectern": "bin/lectern.js"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "app:build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lectern": "tsx src/cli/main.ts"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
